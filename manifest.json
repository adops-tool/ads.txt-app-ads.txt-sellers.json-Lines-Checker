{
  "manifest_version": 3,
  "name": "adWMG Checker: ads.txt/sellers.json",
  "version": "6.7.2",
  "description": "View and filter ads.txt / app-ads.txt files. Automatically matches Company sellers | by OstinUA",
  "icons": {
    "128": "src/assets/icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "action": {
    "default_popup": "src/ui/popup/popup.html",
    "default_title": "Lines Checker"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/ads.txt",
        "*://*/app-ads.txt",
        "*://*/*/ads.txt",
        "*://*/*/app-ads.txt"
      ],
      "js": ["src/content/overlay.js"],
      "run_at": "document_idle"
    }
  ]
}