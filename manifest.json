{
  "manifest_version": 3,
  "name": "adWMG Checker: ads.txt/sellers.json",
  "version": "7.4.0",
  "description": "Validate ads.txt and app-ads.txt files, cross-reference seller IDs with sellers.json, detect errors, and analyze SPO metrics | by OstinUA",
  "icons": {
    "128": "assets/icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_popup": "ui/popup/popup.html",
    "default_title": "Lines Checker"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/ads.txt*",
        "*://*/app-ads.txt*",
        "*://*/*/ads.txt*",
        "*://*/*/app-ads.txt*"
      ],
      "js": ["content/overlay.js"],
      "run_at": "document_idle"
    }
  ]
}